[layer_names]

3d_physics/layer_1="world_spawn"
3d_physics/layer_2="player"
3d_physics/layer_3="trigger_volume"

[physics]

3d/physics_engine="JoltPhysics3D"

[rendering]

textures/canvas_textures/default_texture_filter=3
anti_aliasing/quality/msaa_3d=1
